# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="your_gemini_api_key_here"

# GOOGLE_MAPS_API_KEY: Required for Google Maps Polling Locator.
VITE_GOOGLE_MAPS_API_KEY="your_maps_api_key_here"

# GOOGLE_CLOUD_PROJECT: Required for Google Cloud services (Translate, TTS).
GOOGLE_CLOUD_PROJECT="your_project_id_here"

# FIREBASE_CONFIG: JSON string or individual keys as needed for Firebase SDK.
# Normally provided by firebase-applet-config.json in this environment.
# VITE_FIREBASE_API_KEY, etc.

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Security
FLASK_SECRET_KEY="your_secret_key_here"
ALLOWED_ORIGINS="http://localhost:3000"
