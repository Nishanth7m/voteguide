rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidSession(data) {
      // Basic type validation
      return (data.sessionId == null || data.sessionId is string)
        && (data.messages == null || data.messages is list)
        && (data.language == null || data.language is string)
        && (data.createdAt == null || data.createdAt is timestamp)
        && (data.updatedAt == null || data.updatedAt is timestamp);
    }

    // Sessions collection
    match /sessions/{sid} {
      allow get: if sid is string && sid.size() <= 128;
      allow create: if sid is string && sid.size() <= 128 
        && incoming().sessionId == sid;
      allow update: if sid is string && sid.size() <= 128
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp);
    }
  }
}
